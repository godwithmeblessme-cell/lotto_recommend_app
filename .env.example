# 이 파일을 .env 로 복사한 뒤 실제 값을 채워서 사용하세요.
# .env 파일은 절대 git에 커밋하지 마세요 (.gitignore에 이미 포함되어 있어야 합니다).
#
# ⚠️ 보안 안내: 이전 .project-config.json 파일에는 실제 DB 비밀번호와 JWT_SECRET이
# 평문으로 들어있던 것을 확인하고 제거했습니다. 아래 값들은 전부 "새로" 발급해서 쓰세요.
# (이미 누출된 적이 있는 비밀번호/키는 재사용하면 안 됩니다.)

NODE_ENV=production
PORT=3000

# 직접 호스팅하는 MySQL(또는 호환 DB) 접속 정보. 새로 발급한 비밀번호를 사용하세요.
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DBNAME

# 세션(JWT) 서명용 임의의 긴 무작위 문자열. 예: `openssl rand -base64 48`
JWT_SECRET=

# 관리자 화면 접근을 허용할 사용자의 openId (카카오 로그인 시 "kakao_<숫자ID>" 형태)
OWNER_OPEN_ID=

# --- 카카오 로그인 (developers.kakao.com) ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
# 운영 서버 도메인 기준, 예: https://yourdomain.com/api/oauth/callback
KAKAO_REDIRECT_URI=

# 프론트엔드(Vite)에서도 동일한 클라이언트 ID가 필요합니다.
VITE_KAKAO_CLIENT_ID=

# --- 구글 플레이 인앱결제(Play Billing) 서버 검증 ---
# Play Console에 등록한 패키지명 (예: com.yourcompany.lottoapp)
GOOGLE_PLAY_PACKAGE_NAME=
# Play Console > 설정 > API 액세스에서 만든 서비스 계정 JSON 키 파일의 "내용 전체"를
# 한 줄 문자열로 넣습니다 (예: JSON.stringify 결과를 그대로 붙여넣기).
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# --- Firebase 푸시 알림(FCM) ---
# Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > "새 비공개 키 생성"으로 받은
# JSON 키 파일의 내용 전체를 한 줄로 붙여넣습니다.
FIREBASE_SERVICE_ACCOUNT_JSON=

VITE_APP_TITLE=로또 통계 분석
