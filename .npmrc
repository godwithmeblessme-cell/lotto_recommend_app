# pnpm이 CI 환경(예: 레일웨이 빌드)에서 기본적으로 "frozen-lockfile" 모드로
# 동작하면, package.json에 새 패키지를 추가했을 때 pnpm-lock.yaml과 내용이
# 정확히 일치하지 않는다는 이유로 빌드 자체가 실패할 수 있다.
# (예: "ERR_PNPM_OUTDATED_LOCKFILE")
#
# 이 설정으로 그 동작을 끄고, 대신 pnpm이 알아서 lockfile을 최신 상태로
# 갱신하면서 설치하도록 한다. (배포 자동화 시스템 입장에서는 일반적으로
# "frozen"이 더 안전하지만, 이 프로젝트는 사람이 직접 package.json을 수정해서
# 새 기능을 추가하는 경우가 많아 유연한 설치가 더 안전하다.)
frozen-lockfile=false
